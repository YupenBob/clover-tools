{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node generator.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/landing", "destination": "/landing/index.html" },
    { "source": "/landing/", "destination": "/landing/index.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/changelog", "destination": "/changelog.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/demo2", "destination": "/demo2.html" },
    { "source": "/home-new", "destination": "/home-new.html" },
    { "source": "/", "destination": "/home-new.html" }
  ]
}
