{
  "json/validator": {
    "html": "<div class=\"tool-card\"><h3>输入 JSON</h3><textarea id=\"input\" placeholder=\"粘贴 JSON 数据...\"></textarea></div><div class=\"output-box\"><h3>结果 <button class=\"copy-btn\" id=\"copyOutput\">复制</button></h3><textarea id=\"output\" readonly></textarea></div>",
    "js": "const i=document.getElementById('input'),o=document.getElementById('output');function v(){const t=i.value.trim();if(!t){o.value='';return;}try{const p=JSON.parse(t);o.value='\\u2705 JSON \\u683c\\u5f0f\\u6b63\\u786e\\n\\n\\u89e3\\u6790\\u7ed3\\u679c\\uff1a\\n'+JSON.stringify(p,null,2);}catch(e){o.value='\\u274c JSON \\u9519\\u8bef\\uff1a'+e.message;}}i.addEventListener('input',v);document.getElementById('copyOutput').onclick=()=>copyToClipboard(o.value);v();"
  },
  "json/to-csv": {
    "html": "<div class=\"tool-card\"><h3>JSON 数据</h3><textarea id=\"input\" placeholder=\"\\u8f93\\u5165 JSON \\u6570\\u7ec4\" style=\"min-height:120px;font-family:monospace;\"></textarea><div class=\"btn-row\" style=\"margin-top:0.5rem;\"><button class=\"btn btn-primary\" id=\"toCsv\">JSON\\u2192CSV</button><button class=\"btn btn-secondary\" id=\"fromCsv\">CSV\\u2192JSON</button></div></div><div class=\"output-box\"><h3>\\u8f93\\u51fa <button class=\"copy-btn\" id=\"copyOutput\">\\u590d\\u5236</button></h3><textarea id=\"output\" readonly style=\"font-family:monospace;min-height:120px;\"></textarea></div>",
    "js": "const i=document.getElementById('input'),o=document.getElementById('output');function tc(){try{const t=i.value.trim();if(!t){o.value='';return;}const d=JSON.parse(t),a=Array.isArray(d)?d:[d];if(!a.length){o.value='';return;}const h=[...new Set(a.flatMap(x=>Object.keys(x)))];const csv=[h.join(','),...a.map(r=>h.map(h=>{const v=r[h]===undefined||r[h]===null?'':String(r[h]);return v.includes(',')||v.includes('\"')||v.includes('\\n')?'\"'+v.replace(/\"/g,'\"\"')+'\"':v;}).join(','))].join('\\n');o.value=csv;}catch(e){o.value='Error: '+e.message;}}function fc(){try{const t=i.value.trim();if(!t){o.value='';return;}const ls=t.split('\\n'),h=ls[0].split(',').map(x=>x.trim().replace(/^\"|\"$/g,'')),arr=ls.slice(1).filter(x=>x.trim()).map(line=>{const vals=[],q=false,cur='',j=0;while(j<line.length){const c=line[j];if(c==='\"'){if(q&&line[j+1]==='\"'){cur+='\"';j+=2;}else{q=!q;j++;}}else if(c===','&&!q){vals.push(cur.trim());cur='';j++;}else{cur+=c;j++;}}vals.push(cur.trim());const obj={};h.forEach((h,idx)=>{obj[h]=vals[idx]||'';});return obj;});o.value=JSON.stringify(arr.length===1?arr[0]:arr,null,2);}catch(e){o.value='Error: '+e.message;}}i.addEventListener('input',tc);document.getElementById('toCsv').onclick=tc;document.getElementById('fromCsv').onclick=fc;document.getElementById('copyOutput').onclick=()=>copyToClipboard(o.value);"
  }
}
