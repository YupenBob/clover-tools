{
  "cron-parser": "<div class=\"tool-card\"><div class=\"breadcrumb\">首页 / 开发工具 / Cron 表达式测试</div><h1>Cron 表达式测试</h1><p>验证和解析 Cron 表达式，查看最近N次执行时间</p><div class=\"tool-card\"><h3>Cron 表达式</h3><input id=\"cronInput\" value=\"0 9 * * 1-5\" placeholder=\"* * * * *\" style=\"width:100%;padding:.75rem;font-size:1.1rem;border:1px solid var(--border);border-radius:8px;background:var(--input-bg);color:var(--text);font-family:monospace;box-sizing:border-box\"><div style=\"margin-top:.5rem;font-size:.8rem;color:var(--text-secondary)\">格式: 分 时 日 月 周 &nbsp; 例: 0 9 * * 1-5 = 每天9点(周一至周五)</div><div style=\"display:flex;gap:.5rem;margin-top:.75rem\"><button id=\"btnParse\" class=\"btn btn-primary\">解析</button><select id=\"countSelect\" style=\"padding:.5rem;border-radius:6px;border:1px solid var(--border);background:var(--input-bg);color:var(--text)\"><option value=\"5\">最近5次</option><option value=\"10\">最近10次</option><option value=\"20\">最近20次</option></select></div><div id=\"result\" style=\"background:var(--output-bg);border:1px solid var(--border);border-radius:8px;padding:.75rem;min-height:100px;font-family:monospace;white-space:pre-wrap;margin-top:.75rem;color:var(--text)\"></div></div></div><script>function parseCron(expr){var parts=expr.trim().split(/\\s+/);if(parts.length<5)return null;return{minute:parts[0],hour:parts[1],day:parts[2],month:parts[3],weekday:parts[4]};}function matches(val,field){if(val==='*')return true;if(val.includes(','))return val.split(',').some(function(v){return matches(v.trim(),field);});if(val.includes('-')){var r=val.split('-');var f=parseInt(field);return f>=parseInt(r[0])&&f<=parseInt(r[1]);}if(val.includes('/')){var step=val.split('/')[1];return parseInt(field)%parseInt(step)===0;}return parseInt(field)===parseInt(val);}function nextRuns(cron,count){var runs=[];var d=new Date();d.setSeconds(0);d.setMilliseconds(0);for(var i=0;i<count*10&&runs.length<count;i++){d=new Date(d.getTime()+60000);if(matches(cron.minute,d.getMinutes())&&matches(cron.hour,d.getHours())&&matches(cron.day,d.getDate())&&matches(cron.month,d.getMonth()+1)&&matches(cron.weekday,d.getDay()||7))runs.push(new Date(d));}return runs;}document.getElementById('btnParse').onclick=function(){var cron=parseCron(document.getElementById('cronInput').value);if(!cron){document.getElementById('result').textContent='无效的 Cron 表达式';return;}var cnt=parseInt(document.getElementById('countSelect').value);var runs=nextRuns(cron,cnt);if(runs.length===0){document.getElementById('result').textContent='未来没有匹配的执行时间';return;}document.getElementById('result').textContent='Cron: '+document.getElementById('cronInput').value+'\\n\\n最近'+runs.length+'次执行时间:\\n'+runs.map(function(d){return d.toLocaleString('zh-CN');}).join('\\n');};</script>"
}
